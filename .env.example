# Telegram API credentials — получить на https://my.telegram.org (API development tools)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Порт веб-интерфейса (tg-messenger serve); флаг --port имеет приоритет
TG_WEB_PORT=8090

# Каталог логов (по умолчанию ~/.tg_messenger/logs)
#TG_LOG_DIR=~/.tg_messenger/logs

# --- Шифрование сессий (опционально); нужен extra: pip install -e ".[crypto]" ---
# Если задан — файлы сессий в ~/.tg_messenger/sessions/ шифруются (Fernet, формат enc:v2:).
# Тот же ключ в .env проекта tg_content_factory делает сессии ВЗАИМОЧИТАЕМЫМИ (SSO):
# один логин на оба проекта. Plaintext-сессии при первом чтении с ключом мигрируют в enc:v2:.
# Без ключа всё работает как раньше (сессии лежат plaintext, 0600). Ключ — только в env.
#SESSION_ENCRYPTION_KEY=любая-длинная-секретная-строка-общая-с-фабрикой

# --- ИИ-агент (tg-messenger agent); нужен extra: pip install -e ".[agent]" ---
# Модель в формате provider:model (плюс pip install langchain-anthropic / langchain-openai и ключ провайдера)
#TG_AGENT_MODEL=anthropic:claude-sonnet-4-6
# Кому отвечать: '*' — всем, иначе список числовых id / @username через запятую
# ('*' нельзя смешивать с другими записями).
# @username резолвится по списку диалогов при старте — надёжнее числовой id.
# ВНИМАНИЕ: агент выполняет задания с ПОЛНЫМ доступом к Telegram-инструментам —
# может читать и отправлять сообщения в ЛЮБЫЕ ваши диалоги от вашего имени.
# Добавляйте в список только полностью доверенных людей.
#TG_AGENT_ALLOWLIST=123456789, @username
# Vision-модель для входящих фото (provider:model). Не задана — фото идут
# в основную TG_AGENT_MODEL, тогда она должна быть мультимодальной.
# ПРИВАТНОСТЬ: фото собеседников уходят на серверы LLM-провайдера; при включённом
# LangSmith base64 картинки попадает и в трейсы.
#TG_AGENT_VISION_MODEL=openai:gpt-5.4
# Веб-поиск: duckduckgo (по умолчанию, без ключа) | tavily | exa | brave
#TG_AGENT_SEARCH=duckduckgo
# Кастомные интенты: путь к JSON-конфигу (см. agent.json.example).
# Без переменной берётся ./agent.json из текущего каталога, если он есть.
#TG_AGENT_CONFIG=./agent.json
# Ключи поиска (для tavily/exa/brave): TAVILY_API_KEY / EXA_API_KEY / BRAVE_API_KEY
#TAVILY_API_KEY=tvly-...

# --- Суфлёр (tg-messenger suggest; тот же extra [agent] + TG_AGENT_MODEL) ---
# Черновик ответа в стиле прошлых переписок — для человека, не автоответ.
# Сколько последних сообщений диалога уходит модели как контекст (по умолчанию 30).
# ПРИВАТНОСТЬ: история переписки (и стилевой профиль из ваших ответов) уходит
# на серверы LLM-провайдера; при включённом LangSmith — ещё и в трейсы.
#TG_SUGGEST_HISTORY=30

# Трассировка агента в LangSmith (опционально; кода не требует — langchain/langgraph
# читают эти переменные сами). Ключ: https://smith.langchain.com → Settings → API Keys
# (есть бесплатный план). Включено без ключа = ошибка на старте агента.
# ПРИВАТНОСТЬ: трейсы содержат текст переписки (и base64 фото при vision) —
# всё это сохраняется на серверах LangSmith.
#LANGSMITH_TRACING=true
#LANGSMITH_API_KEY=lsv2_...
#LANGSMITH_PROJECT=tg-messenger
