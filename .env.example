# Telegram API credentials — получить на https://my.telegram.org (API development tools)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Порт веб-интерфейса (tg-messenger serve); флаг --port имеет приоритет
TG_WEB_PORT=8090

# Лимит размера загружаемого файла в веб-композере (МБ); превышение → HTTP 413
#TG_WEB_MAX_UPLOAD_MB=50

# Пароль веб-интерфейса (#24). Если задан — все маршруты за сессией на HMAC-cookie:
# /login (форма), верный пароль → подписанная кука (7 дней, ключ случайный на процесс),
# /logout сбрасывает. Сравнение пароля constant-time, неверная попытка → задержка + WARNING с IP.
# БЕЗ переменной на localhost авторизации нет (как раньше). Для НЕ-localhost
# (например --host 0.0.0.0) пароль ОБЯЗАТЕЛЕН — иначе serve отказывается слушать
# (осознанный обход — флаг --insecure). HTTPS здесь НЕ делается: терминируйте TLS
# на reverse-proxy (nginx/caddy) перед этим сервером.
#TG_WEB_PASS=длинный-секретный-пароль

# Каталог логов (по умолчанию ~/.tg_messenger/logs)
#TG_LOG_DIR=~/.tg_messenger/logs

# Лимит исходящих сообщений в минуту (token-bucket, #25). Покрывает ВСЕ источники
# отправки внутри процесса (agent/heartbeat/moderate/ghostwrite/worker) разом.
# Если не задано, используется безопасный дефолт 20/мин. 0 = ЯВНО ВЫКЛЮЧЕН
# (нет потолка) — команды agent/heartbeat/worker/ghostwrite/moderate при старте
# печатают WARNING в лог.
# ВНИМАНИЕ: лимит НА ПРОЦЕСС, не на аккаунт. Два параллельных отправителя (например
# agent + worker) дадут до 2×TG_SEND_RATE на один аккаунт — учитывайте при запуске
# нескольких одновременно (или запускайте по одному).
# При исчерпании лимита отправка ЖДЁТ (не теряется), с WARNING в лог.
# Систематически высокая частота отправок — риск бана; 20 — консервативный старт.
#TG_SEND_RATE=20

# --- Шифрование сессий (опционально); нужен extra: pip install -e ".[crypto]" ---
# Если задан — файлы сессий в ~/.tg_messenger/sessions/ шифруются (Fernet, формат enc:v2:).
# Тот же ключ в .env проекта tg_content_factory делает сессии ВЗАИМОЧИТАЕМЫМИ (SSO):
# один логин на оба проекта. Plaintext-сессии при первом чтении с ключом мигрируют в enc:v2:.
# Без ключа всё работает как раньше (сессии лежат plaintext, 0600). Ключ — только в env.
#SESSION_ENCRYPTION_KEY=любая-длинная-секретная-строка-общая-с-фабрикой

# --- ИИ-агент (tg-messenger agent); нужен extra: pip install -e ".[agent]" ---
# Модель в формате provider:model (плюс pip install langchain-anthropic / langchain-openai и ключ провайдера)
#TG_AGENT_MODEL=anthropic:claude-sonnet-4-6
# Кому отвечать: '*' — всем, иначе список числовых id / @username через запятую
# ('*' нельзя смешивать с другими записями).
# @username резолвится по списку диалогов при старте — надёжнее числовой id.
# ВНИМАНИЕ: агент выполняет задания с ПОЛНЫМ доступом к Telegram-инструментам —
# может читать и отправлять сообщения в ЛЮБЫЕ ваши диалоги от вашего имени.
# Добавляйте в список только полностью доверенных людей.
#TG_AGENT_ALLOWLIST=123456789, @username
# Vision-модель для входящих фото (provider:model). Не задана — фото идут
# в основную TG_AGENT_MODEL, тогда она должна быть мультимодальной.
# ПРИВАТНОСТЬ: фото собеседников уходят на серверы LLM-провайдера; при включённом
# LangSmith base64 картинки попадает и в трейсы.
#TG_AGENT_VISION_MODEL=openai:gpt-5.4
# Веб-поиск: duckduckgo (по умолчанию, без ключа) | tavily | exa | brave
#TG_AGENT_SEARCH=duckduckgo
# Кастомные интенты: путь к JSON-конфигу (см. agent.json.example).
# Без переменной берётся ./agent.json из текущего каталога, если он есть.
#TG_AGENT_CONFIG=./agent.json
# Ключи поиска (для tavily/exa/brave): TAVILY_API_KEY / EXA_API_KEY / BRAVE_API_KEY
#TAVILY_API_KEY=tvly-...

# --- Перевод сообщений (#62; cache CORE, LLM нужен только для самого перевода) ---
# Язык пользователя: env задаёт default, команда `tg-messenger lang CODE` пишет
# per-profile override в SQLite; `tg-messenger lang --clear` возвращает env/default.
# Иностранные сообщения переводятся лениво при открытии диалога и кэшируются.
#TG_USER_LANG=ru
# Режим перевода входящих: off | all_unknown (по умолчанию: переводить всё, кроме
# моих языков) | skip_known (не переводить языки из списка «знаю») | only_unknown
# (переводить ТОЛЬКО языки из списка). Режим и списки задаются командой
# `tg-messenger lang --mode … --known ru,en --unknown ja,ko` или в TUI (Ctrl+S).
# В TUI блок «Перевод входящих» виден на экране настроек; F1/«?» — справка.
# Модель перевода. Если не задана — берётся TG_AGENT_MODEL. Без модели переводчик
# выключен мягко: SQLite message cache остаётся включённым, UI работает как раньше.
# Модель можно сменить и из TUI (Ctrl+S → «Модель для перевода»): при выборе
# отправляется проб на поддержку structured output (json_schema), результат кэшируется.
#TG_TRANSLATE_MODEL=openai:gpt-5.4
# Сколько последних сообщений переводит один проход «перевести весь чат» (Ctrl+T в TUI).
# env задаёт default; в TUI (Ctrl+S → «Сколько переводить за раз») можно переопределить.
#TG_TRANSLATE_MAX_MESSAGES=100
# Таймаут одного вызова перевода в секундах (по умолчанию 600). Перевод целого чата
# reasoning-моделью может идти минутами — короткий таймаут оборвёт его молча.
#TG_TRANSLATE_TIMEOUT=600
# ПРИВАТНОСТЬ: тексты сообщений, требующих перевода, уходят на серверы LLM-провайдера
# и могут попасть в LangSmith-трейсы, если tracing включён.
# Outbound-перевод (варианты перед отправкой) включён по умолчанию; off = global kill switch.
# Черновики исходящих сообщений тоже уходят LLM-провайдеру.
#TG_OUTBOUND=on

# --- Суфлёр (tg-messenger suggest; тот же extra [agent] + TG_AGENT_MODEL) ---
# Черновик ответа в стиле прошлых переписок — для человека, не автоответ.
# Сколько последних сообщений диалога уходит модели как контекст (по умолчанию 30).
# ПРИВАТНОСТЬ: история переписки (и стилевой профиль из ваших ответов) уходит
# на серверы LLM-провайдера; при включённом LangSmith — ещё и в трейсы.
#TG_SUGGEST_HISTORY=30
# Отдельная (обычно более БЫСТРАЯ) модель для суфлёра. Если не задана — берётся
# TG_AGENT_MODEL. Суфлёр готовит черновик по нажатию Ctrl+G, и быстрая модель
# заметно сокращает ожидание (на медленной модели вызов длится ~20с). Живое
# переопределение модели в настройках (ниже) по-прежнему побеждает этот дефолт.
#TG_SUGGEST_MODEL=openai:glm-5-turbo
# В web/TUI эти параметры также настраиваются в экране настроек (TUI: Ctrl+S →
# «Суфлёр ответов»; web: /settings/suggest): вкл/выкл, размер контекста и
# переопределение модели поверх TG_SUGGEST_MODEL/TG_AGENT_MODEL. Настройки хранятся в
# per-profile SQLite и применяются НА ЛЕТУ (без перезапуска); env остаётся значением по умолчанию.

# --- Ghostwrite (tg-messenger ghostwrite; тот же extra [agent] + TG_AGENT_MODEL) ---
# Полная автоматизация суфлёра: САМ отвечает в стиле владельца в ЯВНО включённых ЛС.
# ⚠ ДЕСТРУКТИВНО — шлёт сообщения от вашего имени. По умолчанию dry-run (только лог);
# реальная отправка — только с флагом --enforce.
# Список диалогов — НЕ env, а отдельный per-dialog allowlist в SQLite:
#   tg-messenger ghostwrite-dialogs enable <dialog_id>
# '*' («всем») ЗАПРЕЩЁН by design — каждый диалог включается явно.
# Предохранители: лимит ответов/час на диалог, авто-пауза при вашем ручном ответе,
# kill switch 'ghostwrite-dialogs pause-all'.
# ПРИВАТНОСТЬ: как у суфлёра — история переписки и стилевой профиль уходят на серверы
# LLM-провайдера (и в LangSmith при трассировке). Accepted risk: allowlist решает,
# в КАКИХ диалогах движок пишет; что он напишет — определяет модель.

# --- Хартбит (tg-messenger heartbeat; CORE, БЕЗ LLM-стека — env НЕ нужен) ---
# Пинги по расписанию с шаблонами и предохранителями. Конфигурация — НЕ env, а планы
# в SQLite: 'heartbeat plan PEER --interval H --template "…"' (повторяющийся план) или
# 'heartbeat plan PEER --at HH:MM --template "…"' (разовая серверная отложенная отправка).
# Запуск планировщика — 'heartbeat run' (Ctrl+C чисто). Предохранители: интервал+jitter,
# quiet hours (локальная TZ), max_per_day и пропуск, если ваше последнее сообщение без ответа.

# Трассировка агента в LangSmith (опционально; кода не требует — langchain/langgraph
# читают эти переменные сами). Ключ: https://smith.langchain.com → Settings → API Keys
# (есть бесплатный план). Включено без ключа = ошибка на старте агента.
# ПРИВАТНОСТЬ: трейсы содержат текст переписки (и base64 фото при vision) —
# всё это сохраняется на серверах LangSmith.
#LANGSMITH_TRACING=true
#LANGSMITH_API_KEY=lsv2_...
#LANGSMITH_PROJECT=tg-messenger

# --- Интероп с tg_content_factory (tg-messenger worker; extra: pip install -e ".[interop]") ---
# Роли: messenger = «руки» (читает/шлёт сообщения через ваш аккаунт), factory = «память
# и поиск» (индекс переписки, очередь заданий). Воркер опрашивает фабрику, исполняет
# задачи (dm_reply/chat_answer → send_text; fetch_history/fetch_dialogs → чтение) и
# рапортует результат обратно. Агентские инструменты factory_search/factory_create_task
# появляются в наборе ТОЛЬКО когда задан TG_FACTORY_URL.
# Авторизация к фабрике — HTTP Basic auth (пустой логин + пароль ниже).
#TG_FACTORY_URL=http://127.0.0.1:8000
#TG_FACTORY_PASSWORD=общий-секрет-с-фабрикой
# ⚠ ACCEPTED RISK (v1, полное доверие): задачи из фабрики исполняются вашим аккаунтом
# БЕЗ дополнительной авторизации источника — кто пишет в очередь фабрики, тот управляет
# вашими «руками» (может слать сообщения и читать любой диалог). Доверяйте фабрике как
# себе; пароль — только в env, никогда в логах/репозитории.
