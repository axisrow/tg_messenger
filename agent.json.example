{
  "//": "Кастомные интенты агента. Скопируйте в ./agent.json (рядом с .env) или укажите путь в TG_AGENT_CONFIG.",
  "//2": "name — одно слово [a-z0-9_-], не из зарезервированных (chat, task, classify, vision, route).",
  "//3": "description — критерий для LLM-классификатора; pipeline — chat (один вызов модели) или task (deep-агент с инструментами).",
  "//4": "system_prompt (опционально) — инструкция интента; подмешивается к сообщению пользователя при вызове.",
  "intents": [
    {
      "name": "translate",
      "description": "просит перевести текст на другой язык",
      "pipeline": "chat",
      "system_prompt": "Ты переводчик. Ответь только переводом, без пояснений."
    },
    {
      "name": "research",
      "description": "просит подробно изучить тему или собрать информацию из интернета",
      "pipeline": "task",
      "system_prompt": "Изучи тему глубоко: несколько поисковых запросов, сверь источники, дай структурированную выжимку."
    }
  ]
}
